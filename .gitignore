# --- Інфраструктура ----------------------------------------------------------
# Дампи БД. Містять ПІБ, телефони, адреси покупців — у git їм не місце ніколи.
*.dump
*.sql.gz
backups/

# --- IDE / ОС ----------------------------------------------------------------
.idea/
.vscode/
!.vscode/extensions.json
*.swp
.DS_Store
Thumbs.db
.vercel
