# =============================================================================
# https://editorconfig.org — однакове форматування незалежно від редактора.
# Узгоджено з ruff (line-length) і prettier.
# =============================================================================
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.py]
indent_size = 4

[*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,css,scss}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{md,mdx}]
indent_size = 2
# У markdown два пробіли в кінці рядка — це <br>. Різати не можна.
trim_trailing_whitespace = false

# Makefile розуміє ТІЛЬКИ таби. Пробіл замість таба = «missing separator».
[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_size = 4

# Caddyfile форматується табами (`caddy fmt` наполягає).
[Caddyfile]
indent_style = tab

[{Dockerfile,Dockerfile.*}]
indent_size = 4

[*.{po,pot}]
insert_final_newline = false
