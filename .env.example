# =============================================================================
# Complex — оточення ПРОД-СТЕКУ (docker compose).  Копія:  cp .env.example .env
#
# ⚠️ ЦЕЙ ФАЙЛ — НЕ ДЛЯ ЛОКАЛЬНОЇ РОЗРОБКИ.
#    Локальний бекенд читає backend/.env  (див. backend/.env.example).
#    Тут — тільки те, що потрібно docker compose на VPS.
#
# ⚠️ СЕКРЕТІВ ТУТ НЕМАЄ І БУТИ НЕ МОЖЕ.
#    Паролі, приватні ключі й токени їдуть ФАЙЛАМИ через `docker compose secrets`
#    (infra/secrets/*, створюються `make secrets-init`). Причина: env видно в
#    `docker inspect`, у краш-дампах і в breadcrumbs Sentry.
#    Виняток — POSTGRES_PASSWORD: офіційний образ postgres інакше не вміє, і
#    база все одно не виглядає назовні (порт не публікується).
# =============================================================================

# --- Домен і TLS ----------------------------------------------------------
SITE_DOMAIN=complex.ua
SITE_URL=https://complex.ua
ACME_EMAIL=admin@complex.ua

DJANGO_ALLOWED_HOSTS=complex.ua,www.complex.ua,web,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://complex.ua,https://www.complex.ua
DJANGO_LOG_LEVEL=INFO

# --- Адмінка --------------------------------------------------------------
# ⚠️ ДВІ ЗМІННІ, ОДИН ШЛЯХ. Розійдуться — rate-limit Caddy тихо перестане
#    працювати (він лімітуватиме неіснуючий шлях), а логін адмінки лишиться
#    відкритим для перебору. Django хоче зі слешем на кінці, Caddy — без слешів.
ADMIN_URL=_adm_CHANGE_ME/
ADMIN_PATH=_adm_CHANGE_ME

# --- PostgreSQL -----------------------------------------------------------
# ⚠️ POSTGRES_USER=postgres — не лінь, а вимога:
#    1. міграції роблять CREATE EXTENSION (pg_trgm, btree_gin, unaccent — ADR-022),
#       а це може тільки суперюзер;
#    2. pgBackRest і restore-drill ходять у БД через unix-сокет з peer-авторизацією
#       від ОС-користувача postgres. Перейменуєш — зламаєш бекапи.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_довгий_випадковий_рядок
# ⚠️ `nisa` — ІСТОРИЧНА назва (проєкт перейменовано на Complex 14.07.2026). Ім'я БД
#    свідомо НЕ міняємо: rename БД = новий том/дамп+restore і перестворення станзи
#    pgBackREST. Об'єкти всередині БД уже перейменовані (complex_price_uah() тощо).
POSTGRES_DB=nisa
DB_CONN_MAX_AGE=60

# --- Cloudflare R2: медіа і знімки прогонів -------------------------------
# Токен ЗАСТОСУНКУ. Прав на бакет бекапів у нього НЕМАЄ (див. нижче).
R2_ACCESS_KEY_ID=CHANGE_ME
# R2_SECRET_ACCESS_KEY → infra/secrets/r2_secret_access_key
R2_BUCKET=complex-media
R2_SNAPSHOTS_BUCKET=complex-sync-snapshots
R2_ENDPOINT_URL=https://CHANGE_ME.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN=cdn.complex.ua
R2_REGION=auto

# --- Cloudflare R2: БЕКАПИ (ОКРЕМИЙ бакет, ОКРЕМИЙ токен) -----------------
# 🔴 ЦЕ НЕ ФОРМАЛЬНІСТЬ (ADR-019). Якщо бекапи лежать у тому ж бакеті і під тим
#    самим токеном, що й медіа, то компрометація web/worker зносить І ДАНІ,
#    І БЕКАПИ одним рухом. Бекап, доступний на запис із застосунку, — не бекап.
#    Токен нижче має права ТІЛЬКИ на бакет бекапів; токен застосунку (R2_*)
#    прав на цей бакет НЕ МАЄ ВЗАГАЛІ.
# ⚠️ Станза `nisa` — ІСТОРИЧНА назва, свідомо НЕ перейменована: станза — це ідентичність
#    бекап-репозиторію. Зміна імені робить УСІ наявні бекапи й WAL невидимими для
#    pgbackrest (потрібен stanza-create + повний бекап з нуля). Не варте ребрендингу.
PGBACKREST_STANZA=nisa
PGBACKREST_R2_BUCKET=complex-backups
PGBACKREST_R2_ENDPOINT=CHANGE_ME.r2.cloudflarestorage.com
PGBACKREST_R2_KEY=CHANGE_ME
# PGBACKREST_R2_KEY_SECRET  → infra/secrets/pgbackrest_s3_secret
# Пароль шифрування репозиторію → infra/secrets/pgbackrest_cipher_pass
#   ⚠️ КОПІЮ ЦЬОГО ПАРОЛЯ ТРИМАЙ ПОЗА VPS. Втратиш — бекапи не розшифруються.

# --- Google Sheets --------------------------------------------------------
# Google Cloud проєкт:  complex-502407
# Сервісний акаунт:     complex-sync@complex-502407.iam.gserviceaccount.com
#   ⚠️ Обидві таблиці мають бути розшарені на цю адресу («Читач»), інакше Sheets API
#      віддасть 403 і синк тихо піде у фікстурний режим (sync.sheets.is_fixture_mode()).
SHEETS_PRICE_SPREADSHEET_ID=12xmgixwelF621CPRhd9gqxNRrIW1RF-vLfHsAA4Dohc
SHEETS_SPEC_SPREADSHEET_ID=1qgMFRcTcH2Jt1q1kICmOYVJQiXSPzZpCVdP8UogqjDY
# JSON сервісного акаунта (ключ complex-sync@…) → infra/secrets/google_sa.json
# У контейнер приїжджає як docker secret /run/secrets/google_sa.json

# --- Нова Пошта / LiqPay / Claude -----------------------------------------
# NP_API_KEY            → infra/secrets/np_api_key
LIQPAY_PUBLIC_KEY=
# LIQPAY_PRIVATE_KEY    → infra/secrets/liqpay_private_key
LIQPAY_SANDBOX=False
# 🔴 Публічний URL БЕКЕНДА для server_url вебхука LiqPay:
#    {PAYMENTS_PUBLIC_URL}/api/v1/payments/liqpay/callback  — має бути публічний HTTPS.
#    SITE_URL не годиться (це фронт). Порожньо → фолбек на SITE_URL.
#    ⚠️ Потребує рядка у config/settings/base.py: PAYMENTS_PUBLIC_URL = env(..., default="")
PAYMENTS_PUBLIC_URL=https://complex.ua
# ANTHROPIC_API_KEY     → infra/secrets/anthropic_api_key
AI_MONTHLY_BUDGET_USD=50
# ШІ-асистент у чаті («лисичка»). Hard-cap саме на чат — публічний LLM-ендпоінт
# без стелі це відкритий гаманець. Деталі — backend/.env.example.
ANTHROPIC_ASSISTANT_MODEL=claude-opus-4-8
ASSISTANT_MONTHLY_BUDGET_USD=50

# --- Hotline --------------------------------------------------------------
HOTLINE_FIRM_ID=

# Куди generate_hotline_feed пише hotline.xml. У проді — НАЗВАНИЙ ТОМ feeds_data
# (docker-compose: worker пише rw, Caddy монтує :ro і віддає з /srv/feeds).
# 🔴 НЕ шлях усередині коду контейнера: `compose up -d` зніс би файл разом із шаром,
#    а Hotline через 7 днів без оновлення МОВЧКИ припиняє публікацію каталогу.
# Порожньо → фолбек на MEDIA_ROOT/feeds (локальна розробка).
HOTLINE_FEED_DIR=/srv/feeds

# --- Моніторинг і алерти --------------------------------------------------
# TELEGRAM_BOT_TOKEN    → infra/secrets/telegram_bot_token
TELEGRAM_CHAT_ID=

# Dead-man's switch (Healthchecks.io). Порожньо → алертів НЕ БУДЕ, і мовчазна
# смерть beat/cron лишиться непоміченою на тижні. Заповни (ARCHITECTURE ADR-019).
HEALTHCHECKS_SYNC_URL=
HEALTHCHECKS_BACKUP_URL=
HEALTHCHECKS_DRILL_URL=

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05

# Проставляє deploy.yml (git SHA релізу) — Sentry по ньому зшиває помилки з кодом.
GIT_SHA=dev

# --- Пошта ----------------------------------------------------------------
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD   → infra/secrets/email_host_password
DEFAULT_FROM_EMAIL=noreply@complex.ua

# NEXT_REVALIDATE_SECRET → infra/secrets/next_revalidate_secret
