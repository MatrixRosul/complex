# =============================================================================
# Complex — приклад оточення.  Скопіюй у .env:  cp .env.example .env
# У проді секрети (LIQPAY_PRIVATE_KEY, ANTHROPIC_API_KEY, google_sa.json)
# їдуть через `docker compose secrets:` (файли), а не через env — INTEGRATIONS §4.
# =============================================================================

# --- Django ---------------------------------------------------------------
# У проді — ОБОВ'ЯЗКОВО свій: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=insecure-dev-key-change-me
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# Публічний URL фронтенду (Next.js). Використовується в листах, sitemap, CSRF_TRUSTED_ORIGINS.
SITE_URL=http://localhost:3000

# Адмінка НЕ на /admin/ (ARCHITECTURE §5). У проді — довгий непередбачуваний префікс.
ADMIN_URL=admin/
# ADMIN_URL=_adm_7f3a9c21/

# --- База даних (PostgreSQL 14!) -----------------------------------------
# ⚠️ Ім'я БД `nisa` — ІСТОРИЧНЕ (стара назва проєкту). Свідомо НЕ перейменовуємо:
#    інакше треба перестворювати локальні бази й станзу pgBackREST. Об'єкти всередині
#    БД уже під новою назвою: complex_price_uah(), complex_log_price(), ru_complex.
DATABASE_URL=postgres://maxrosul@localhost:5432/nisa
DB_CONN_MAX_AGE=60

# --- Redis ----------------------------------------------------------------
# db0 = broker (ОБОВ'ЯЗКОВО maxmemory-policy noeviction — інакше черга мовчки їсть задачі)
# db1 = кеш (allkeys-lru), db2 = result backend
REDIS_URL=redis://localhost:6379
REDIS_CACHE_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Локально: True → задачі виконуються синхронно, без воркера
CELERY_TASK_ALWAYS_EAGER=False

# --- Безпека адмінки ------------------------------------------------------
AXES_ENABLED=False
AXES_FAILURE_LIMIT=5
# True тільки за reverse-proxy (Caddy) — інакше axes банитиме IP проксі
AXES_BEHIND_REVERSE_PROXY=False

# --- Cloudflare R2 (S3-сумісне сховище) -----------------------------------
USE_R2=False
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=complex-media
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN=cdn.complex.ua
R2_REGION=auto
# Окремий бакет для сирих знімків прогонів синку (SYNC.md §2, крок 7)
R2_SNAPSHOTS_BUCKET=complex-sync-snapshots

# --- Google Sheets --------------------------------------------------------
# Google Cloud проєкт:  complex-502407
# Сервісний акаунт:     complex-sync@complex-502407.iam.gserviceaccount.com
#   ⚠️ Обидві таблиці нижче мають бути розшарені на ЦЮ адресу (доступ «Читач» достатньо),
#      інакше Sheets API віддасть 403 і синк тихо піде у ФІКСТУРНИЙ РЕЖИМ (див. нижче).
#
# Шлях до JSON сервісного акаунта (ключ complex-sync@…). У проді — docker secret
# (у private_key є \n!), локально — файл infra/secrets/google_sa.json (він у .gitignore).
# ⚠️ Шлях резолвиться від CWD (sheets.py::_service_account_info → Path(...).is_file()),
#    а manage.py запускають з backend/ → звідси `../`.
GOOGLE_SA_JSON_PATH=../infra/secrets/google_sa.json
# GOOGLE_SA_JSON_PATH=/run/secrets/google_sa.json   # прод (docker compose secret)
# Альтернативи (читає sync/sheets.py::_service_account_info(), пріоритет саме такий):
#   GOOGLE_SA_JSON — увесь JSON ОДНИМ РЯДКОМ (для CI / хостингів без файлових секретів)
#   GOOGLE_SA_FILE — шлях до файла (перекриває GOOGLE_SA_JSON_PATH)
# GOOGLE_SA_JSON={"type":"service_account", ...}
# GOOGLE_SA_FILE=/run/secrets/google_sa.json
#
# --- Google OAuth: ЗАПАСНИЙ шлях до Sheets (коли ключ SA створити НЕ МОЖНА) ----
# 🔴 НАВІЩО ЦЕ ІСНУЄ. Політика Google Cloud організації замовника
#    `iam.disableServiceAccountKeyCreation` ЗАБОРОНЯЄ створювати ключі сервісних акаунтів.
#    Тобто GOOGLE_SA_* вище зараз фізично нічим заповнити. Обхід: ходимо в Sheets
#    OAuth-токеном ЖИВОГО КОРИСТУВАЧА (maxrosul4@gmail.com), якому таблиці розшарені на перегляд.
#
#    ПРІОРИТЕТ ДЖЕРЕЛ (sync/sheets.py::get_client): service account → OAuth → фікстури.
#    Тому щойно політику знімуть і з'явиться ключ SA — синк перемкнеться на нього САМ,
#    без жодних правок коду. OAuth-токен тоді можна просто видалити.
#
#    Разова авторизація (інтерактивна, відкриє браузер):  manage.py google_auth
#    Діагностика «а що ти зараз бачиш»:                   manage.py sheets_info
#    Scope — ТІЛЬКИ читання (spreadsheets.readonly): писати в чужі таблиці ми не просимо.
#
# Client secrets Desktop-клієнта ({"installed": {...}} з Cloud Console → Credentials).
# ⚠️ Обидва файли — СЕКРЕТИ, обидва в .gitignore. google_token.json = доступ до таблиць БЕЗ пароля.
GOOGLE_OAUTH_CLIENT_FILE=google_oauth.json
# Куди лягає токен (access + refresh) після manage.py google_auth. Права файла — 0600.
GOOGLE_OAUTH_TOKEN_FILE=google_token.json

# ⚠️ НЕМАЄ НІ SA, НІ OAuth-ТОКЕНА → ФІКСТУРНИЙ РЕЖИМ: синк читає CSV з backend/sync/fixtures/
#    і повністю працює без доступу до чужих таблиць.
#    Локально це норма; У ПРОДІ це означає, що зник секрет — і прайс синкається з фікстур.
#    Перевірка в адмінці/логах: sync.sheets.is_fixture_mode() / sync.sheets.sheets_mode().
# SYNC_FIXTURES_DIR=/шлях/до/своїх/фікстур   # дефолт: backend/sync/fixtures

# Прайс (2 листи: UAH + USD)
SHEETS_PRICE_SPREADSHEET_ID=12xmgixwelF621CPRhd9gqxNRrIW1RF-vLfHsAA4Dohc
# Таблиця характеристик, лист «Гривнева» (SYNC.md §1.5.3)
SHEETS_SPEC_SPREADSHEET_ID=1qgMFRcTcH2Jt1q1kICmOYVJQiXSPzZpCVdP8UogqjDY

# --- Нова Пошта -----------------------------------------------------------
NP_API_KEY=
NP_API_URL=https://api.novaposhta.ua/v2.0/json/

# --- LiqPay ---------------------------------------------------------------
LIQPAY_PUBLIC_KEY=
# У проді — docker secret, НЕ env (INTEGRATIONS §4)
LIQPAY_PRIVATE_KEY=
LIQPAY_SANDBOX=True

# 🔴 ПУБЛІЧНИЙ URL БЕКЕНДА — з нього будується `server_url` вебхука LiqPay:
#    {PAYMENTS_PUBLIC_URL}/api/v1/payments/liqpay/callback
#    SITE_URL для цього НЕ ГОДИТЬСЯ: це фронт (Next.js, :3000), а вебхук має прийти в Django.
#    Має бути ПУБЛІЧНИЙ HTTPS. Локально — cloudflared/ngrok; порожньо → фолбек на SITE_URL.
#    ⚠️ ПОТРІБЕН РЯДОК У config/settings/base.py (його править власник settings):
#       PAYMENTS_PUBLIC_URL = env("PAYMENTS_PUBLIC_URL", default="")
PAYMENTS_PUBLIC_URL=

# Скільки годин дійсне посилання на оплату (expired_date у чекауті). Дефолт у коді — 24.
# LIQPAY_INVOICE_TTL_HOURS=24
# Версія API LiqPay (у прикладах — 3; у таблиці параметрів згадується 7). Дефолт у коді — 3.
# LIQPAY_API_VERSION=3

# --- Claude API (переклад uk→ru, збір характеристик) ----------------------
# У проді — docker secret, НЕ env.
# Порожній ключ = DRY-RUN: модуль перекладу не падає, а повертає заглушку (витрати $0).
ANTHROPIC_API_KEY=

# ⚠️ МОДЕЛІ. Не міняй на 4-5 назад — на claude-sonnet-4-5 модуль перекладу не працює:
#    у неї немає ані structured outputs (output_config.format), ані output_config.effort.
#    Без structured outputs модель повертає JSON «як вийде» і парсер лягає на першому ж
#    описі з лапками. translation/conf.py це відловлює й гучно попереджає, але правильні
#    значення мають бути тут (TRANSLATION.md §7.2).
#
#    Обсяг (назви, описи, SEO) — Sonnet 5: переклад не задача на ризонінг, а ціна/якість
#    найкраща. Інтро-ціна $2/$10 за 1M діє до 31.08.2026, далі $3/$15.
ANTHROPIC_TRANSLATION_MODEL=claude-sonnet-5
#    СЛОВНИК характеристик і ретраї після FAILED/відхилення — Opus 4.8: обсяг мізерний
#    (~4 300 коротких рядків, ~$0.65), а текст реплікується в 300 000 місць каталогу.
ANTHROPIC_TRANSLATION_DICT_MODEL=claude-opus-4-8
ANTHROPIC_HARVEST_MODEL=claude-opus-4-8

# Ліміт витрат на місяць, USD. Перевищення → задачі ai-черги зупиняються + алерт.
AI_MONTHLY_BUDGET_USD=50
# Hard-cap саме для перекладу (TRANSLATION.md §7.5): при перевищенні translate_pending
# не сабмітить батчі, а кидає BudgetExceeded. Дешевше запобіжник, ніж пояснювати рахунок.
TRANSLATION_MONTHLY_BUDGET_USD=50

# --- ШІ-асистент («лисичка» в чаті) ---------------------------------------
# Модель для чат-консультанта. Opus 4.8 — бо це tool-calling: модель мусить сама
# вирішити, який з 6 інструментів каталогу викликати і з якими параметрами.
# На дешевших моделях падає should-call rate → асистент відповідає «з голови»,
# а це рівно те, чого ми не можемо допустити (вигадана ціна = скарга покупця).
ANTHROPIC_ASSISTANT_MODEL=claude-opus-4-8
# Hard-cap витрат на чат за місяць, USD. Публічний LLM-ендпоінт — це відкритий
# гаманець: без стелі один бот за ніч з'їдає місячний бюджет. Перевищення →
# асистент м'яко відмовляє і дає телефон менеджера, а не падає з 500.
ASSISTANT_MONTHLY_BUDGET_USD=50
# Ліміти одного діалогу (друга лінія оборони, поверх rate-limit 20 запитів/хв на IP).
ASSISTANT_MAX_MESSAGES=30
ASSISTANT_MAX_INPUT_CHARS=1000

# --- Hotline --------------------------------------------------------------
HOTLINE_FIRM_ID=

# Куди generate_hotline_feed пише hotline.xml.
# Порожньо → MEDIA_ROOT/feeds (тобто backend/media/feeds/hotline.xml) — так і треба локально.
# У проді — named volume /srv/feeds, звідки файл віддає Caddy (див. кореневий .env.example).
# HOTLINE_FEED_DIR=

# --- Next.js ISR ----------------------------------------------------------
NEXT_REVALIDATE_URL=http://localhost:3000/api/revalidate
NEXT_REVALIDATE_SECRET=

# --- Алерти й моніторинг --------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Dead-man's switch: мовчазна смерть beat = найчастіший реальний збій (ARCHITECTURE §5)
HEALTHCHECKS_SYNC_URL=

# --- Sentry (опційно: порожній DSN → Sentry не вмикається) ----------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.05
GIT_SHA=

# --- Пошта (prod) ---------------------------------------------------------
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@complex.ua
